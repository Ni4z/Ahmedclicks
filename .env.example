# Copy this file to .env.local and fill in your values
# This file should NOT be committed to version control

# Google Analytics ID
# Get this from https://analytics.google.com
NEXT_PUBLIC_GA_ID=

# Contact Email - Where contact form submissions should be sent to
NEXT_PUBLIC_CONTACT_EMAIL=hello@ahmedphotography.com

# Optional: Public base URL for externally hosted portfolio videos
# Example: https://videos.niazphotography.com
NEXT_PUBLIC_VIDEO_BASE_URL=

# Optional: Public base URL for externally hosted portfolio images
# Example: https://images.niazphotography.com
NEXT_PUBLIC_IMAGE_BASE_URL=

# Optional: Shared public base URL for both images and videos
# Example: https://media.niazphotography.com
NEXT_PUBLIC_MEDIA_BASE_URL=

# R2 sync settings used by scripts/sync-r2-media.mjs
# Required for automatic bucket pickup during npm run dev / npm run build / npm run sync:media
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: use this instead of R2_ACCOUNT_ID if you prefer the full endpoint
# Example: https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Optional: limit scanning to specific prefixes
# Leave blank if you want the script to detect photos/videos anywhere in the bucket
R2_PHOTO_PREFIX=
R2_PHOTO_THUMB_PREFIX=photos-thumb
R2_VIDEO_PREFIX=

# Optional: Email Service Configuration
# If using Nodemailer or similar
# SENDGRID_API_KEY=
# MAILGUN_API_KEY=
# GMAIL_APP_PASSWORD=
