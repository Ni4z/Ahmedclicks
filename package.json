{
  "name": "niazphotography",
  "version": "1.0.0",
  "description": "Photography portfolio website for NiazPhotography",
  "private": true,
  "scripts": {
    "predev": "node scripts/sync-r2-media.mjs",
    "prebuild": "node scripts/sync-r2-media.mjs",
    "sync:media": "node scripts/sync-r2-media.mjs",
    "thumbs:setup": "bash scripts/setup-thumbnail-worker.sh",
    "thumbs:deploy": "npx wrangler deploy -c workers/thumbnail-generator/wrangler.jsonc",
    "thumbs:backfill": "node scripts/backfill-r2-thumbnail.mjs",
    "thumbs:heal": "node scripts/heal-r2-thumbnails.mjs",
    "thumbs:dev": "npx wrangler dev -c workers/thumbnail-generator/wrangler.jsonc",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@types/nodemailer": "^6.4.0",
    "autoprefixer": "^10.4.0",
    "framer-motion": "^10.16.0",
    "next": "^15.5.2",
    "next-image-export-optimizer": "^1.17.0",
    "nodemailer": "^6.9.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.0",
    "yet-another-react-lightbox": "^3.10.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "typescript": "^5.0.0"
  }
}
